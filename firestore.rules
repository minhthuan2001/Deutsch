rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Topics and Words can be read by anyone; writes are permitted for seeding and management
    match /topics/{topicId} {
      allow read: if true;
      allow write: if true;
    }
    match /words/{wordId} {
      allow read: if true;
      allow write: if true;
    }
    
    // User profile rules
    match /users/{userId} {
      // Anyone can read profiles (necessary for Leaderboard)
      allow read: if true;
      // Only the logged-in user can write to their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Topic Progress subcollection
      match /progress/{topicId} {
        // Only the owner can read/write their own progress
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
